@model RefugioAnimales.ViewModel.PanelUsuariosViewModel

@{
    ViewData["Title"] = "Usuarios";
}

<h4>Panel de @Model.Usuario.NombreUsuario</h4>

<div>
    <div>
        <p><a asp-action="Panel" class="">Cambiar contraseña</a><span> | </span>Lista de Usuarios</p>
    </div>
    <hr />
<p>
        <a asp-action="Crear" class="btn btn-success">Crear usuario</a>
</p>
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Usuario.Id)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Usuario.NombreUsuario)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Usuario.Rol)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Usuarios)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.NombreUsuario)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Rol)
                    </td>
                    <td>
                        <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-primary">Editar</a>
                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-secondary">Detalles</a>
                        @if (item.Id != Model.Usuario.Id)
                        {
                            <a asp-action="Eliminar" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
