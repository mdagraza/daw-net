@model RefugioAnimales.ViewModel.AnimalViewModel

@{
    ViewData["Title"] = "Eliminar";
}

<h1>Eliminar</h1>

<h3>¿Estás seguro de que quieres eliminar a <em>@Html.DisplayFor(model => model.Nombre)?</em></h3>
<div>
    <hr />
    <dl class="row g-5">
        <div class="col-2">

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Especie)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Especie)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Edad)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Edad)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Estado)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Estado)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.Descripcion)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Descripcion)
            </dd>
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AdoptanteNombre)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AdoptanteNombre)
            </dd>
            @if (Model.FechaAdopcion != null)
            {
                <dt class="col-sm-2">
                    @Html.DisplayNameFor(model => model.FechaAdopcion)
                </dt>

                <dd class="col-sm-10">
                    @Html.DisplayFor(model => model.FechaAdopcion)
                </dd>
            }
        </div>
        <div class="col">
            <img src="data:@Model.FotoMimeType;base64,@Convert.ToBase64String(@Model.FotoContenido)"
                 alt="Foto de @Model.Nombre"
                 style="max-width:500px; height:auto;" />
        </div>
    </dl>
    
    <form asp-action="Eliminar">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Eliminar" class="btn btn-danger" />
        <a asp-action="Animales" class="btn btn-secondary">Volver a la lista</a>
    </form>
</div>
