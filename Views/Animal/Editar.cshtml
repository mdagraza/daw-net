@model RefugioAnimales.ViewModel.AnimalEditarViewModel

@{
    ViewData["Title"] = "Editar Animal";
}

<h1>Editar a @Model.Nombre</h1>

<hr />
<div class="row">
    <div class="col-md-6">

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success">
                @TempData["Mensaje"]
            </div>
        }

        <form asp-action="Editar" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <!-- Nombre -->
            <div class="form-group">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <!-- Especie -->
            <div class="form-group">
                <label asp-for="Especie" class="control-label"></label>
                <input asp-for="Especie" class="form-control" />
                <span asp-validation-for="Especie" class="text-danger"></span>
            </div>

            <!-- Edad -->
            <div class="form-group">
                <label asp-for="Edad" class="control-label"></label>
                <input asp-for="Edad" class="form-control" />
                <span asp-validation-for="Edad" class="text-danger"></span>
            </div>

            <!-- Estado (SelectList) -->
            <div class="form-group">
                <label asp-for="EstadoId" class="control-label"></label>
                <select asp-for="EstadoId" asp-items="Model.EstadoLista" class="form-control"></select>
                <span asp-validation-for="EstadoId" class="text-danger"></span>
            </div>

            <!-- Descripcion -->
            <div class="form-group">
                <label asp-for="Descripcion" class="control-label"></label>
                <textarea asp-for="Descripcion" class="form-control"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <!-- Foto actual -->
            @if (Model.FotoContenido != null && Model.FotoContenido.Length > 0)
            {
                <div class="form-group mt-3">
                    <label asp-for="FotoContenido" class="control-label"></label><br />
                    <img src="data:@Model.FotoMimeType;base64,@Convert.ToBase64String(Model.FotoContenido)"
                         style="max-width:250px; border:1px solid #ccc; padding:4px;" />
                </div>
            }

            <!-- Subir nueva foto -->
            <div class="form-group mt-2">
                <label for="FotoContenido">Subir nueva foto (Dejar vacío si no se quiere cambiar)</label>
                <input type="file" name="FotoContenido" class="form-control" />
            </div>

            @* Si no hay fecha de adopcion, no se muestra (Se entiende que no esta adoptado) *@
            @if (Model.FechaAdopcion.HasValue)
            {
                <!-- Fecha Adopción -->
                <div class="form-group">
                    <label asp-for="FechaAdopcion" class="control-label"></label>
                    <input asp-for="FechaAdopcion" class="form-control" type="date" />
                    <span asp-validation-for="FechaAdopcion" class="text-danger"></span>
                </div>
            }
            <br/>
            <div class="form-group">
                <input type="submit" value="Guardar" class="btn btn-success" />
                <a asp-action="Animales" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

