@model RefugioAnimales.ViewModel.AnimalAdoptarViewModel

@{
    ViewData["Title"] = "Adoptar";
}

<h1>Adoptar a @Model.Nombre</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Adoptar" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="AdoptanteId" class="control-label"></label>
                <select asp-for="AdoptanteId" asp-items="Model.Adoptantes" class="form-control"></select>
                <span asp-validation-for="AdoptanteId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaAdopcion" class="control-label"></label>
                <input asp-for="FechaAdopcion" class="form-control" type="datetime-local" />
                <span asp-validation-for="FechaAdopcion" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Confirmar adopción" class="btn btn-success" />
                <a asp-action="Animales" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>