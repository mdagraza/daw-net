@model RefugioAnimales.ViewModel.AnimalViewModel

@{
    ViewData["Title"] = "Desadoptar";
}

<h1>Desadoptar a @Model.Nombre</h1>

<h3>¿Estás seguro de que quieres desadoptar a <em>@Html.DisplayFor(model => model.Nombre)?</em></h3>
<div>
    <h4>Animal</h4>
    <hr />
    <dl class="row">
        <div class="col-auto">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.AdoptanteNombre)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.AdoptanteNombre)
            </dd>
            
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.FechaAdopcion)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.FechaAdopcion)
            </dd>
            
        </div>
    </dl>

    <form asp-action="Desadoptar">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Desadoptar" class="btn btn-warning" />
        <a asp-action="Animales" class="btn btn-secondary">Volver a la lista</a>
    </form>
</div>